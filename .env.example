# =============================================================
#  SchoolSec - Template variabile de mediu
#  Copiați acest fișier în .env și completați valorile.
#  NU includeți .env în git (este deja în .gitignore).
# =============================================================

# ------------------------------------------------------------
# Mediul de rulare: development | production
# ------------------------------------------------------------
FLASK_ENV=development

# ------------------------------------------------------------
# SECRET_KEY — obligatoriu în producție!
# Generați o valoare aleatorie cu:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
SECRET_KEY=schimbati-aceasta-valoare-cu-una-aleatorie-puternica

# ------------------------------------------------------------
# HTTPS / SSL (opțional — recomandat în producție)
# Generați un certificat auto-semnat (development/test):
#   openssl req -x509 -newkey rsa:4096 -nodes \
#     -out cert.pem -keyout key.pem -days 365
# Pentru producție folosiți un certificat valid (Let's Encrypt etc.)
# ------------------------------------------------------------
SSL_CERT=cert.pem
SSL_KEY=key.pem

# ------------------------------------------------------------
# Portul serverului web (implicit 5000)
# ------------------------------------------------------------
PORT=5000

# ------------------------------------------------------------
# Modul sniffer: simulated | interface | tzsp
# ------------------------------------------------------------
SNIFFER_MODE=simulated

# Interfața de rețea pentru modul 'interface' (ex: eth0, wlan0)
# NETWORK_INTERFACE=eth0

# ------------------------------------------------------------
# MikroTik RouterOS API (opțional)
# Serverul poate fi instalat oriunde pe rețea - nu necesită
# conexiune fizică directă sau port mirroring la router.
# TZSP (UDP:37008) și API (TCP:8728) funcționează independent.
# ------------------------------------------------------------
MIKROTIK_ENABLED=false
# MIKROTIK_HOST=192.168.88.1
# MIKROTIK_PORT=8728
# MIKROTIK_USERNAME=admin
# MIKROTIK_PASSWORD=
# Intervalul (secunde) pentru sincronizarea DHCP, conexiuni și statistici
# MIKROTIK_SYNC_INTERVAL=60
# Monitorizare atacuri externe prin loguri firewall (activ când MIKROTIK_ENABLED=true)
# EXTERNAL_MONITOR_ENABLED=true

# ------------------------------------------------------------
# Notificări Telegram (opțional)
# ------------------------------------------------------------
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=-1001234567890
# TELEGRAM_MIN_SEVERITY=critical
